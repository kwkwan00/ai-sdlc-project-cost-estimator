# ---- Anthropic (required) ----
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# The six estimation twins use ANTHROPIC_MODEL (Sonnet). The pre-submission/merge
# agents below pin their own tier — Haiku for the cheap/fast passes, Sonnet for the
# knowledge-heavy roster/tooling agents. Override here if desired:
ANTHROPIC_MODEL_PREFILL=claude-haiku-4-5
ANTHROPIC_MODEL_ROSTER=claude-sonnet-4-6
# Consolidates near-duplicate clarifying questions in merge_pass1 (falls back to
# deterministic topic-dedup if unset/unreachable):
ANTHROPIC_MODEL_MERGE=claude-haiku-4-5
# Classifies the freeform Stage 3 AI-tooling description into per-phase levels:
ANTHROPIC_MODEL_TOOLING=claude-sonnet-4-6
# The WBS planner (drafts the bottom-up task tree) + completeness critic. A deep-reasoning
# decomposition task — effectively a whole-project brainstorm — → Claude Opus 4.8 with `max` effort
# by default (the top reasoning tier). Set a gpt-* id to use OpenAI instead (needs OPENAI_API_KEY
# below). WBS_REASONING_EFFORT maps to output_config.effort (low|medium|high|xhigh|max; xhigh is
# model-dependent, max is universally supported) on Anthropic and reasoning_effort (adds minimal|
# xhigh) on OpenAI. Drop to high|medium to trade decomposition depth for latency/cost.
WBS_MODEL=claude-opus-4-8
WBS_REASONING_EFFORT=max
# Global tuning scale on the WBS bottom-up realism factor. The drafted leaf hours are scaled up by
# a COMPLEXITY-AWARE factor derived from the project's own signals (regulatory regimes, integrations,
# screens, project type, codebase familiarity) to correct bottom-up optimism. This knob globally
# scales that factor: 1.0 (default) = use it as computed; >1 nudges all estimates up, <1 down.
WBS_EFFORT_SCALE=1.0
# How far up the AI-reduction guardrail band the WBS flow anchors its per-phase reduction for the
# coding phases (development/code_review/deployment/qa) — 0.5 = band midpoint (optimistic), lower =
# more conservative. Default 0.3 keeps WBS AI savings in line with the parametric/twin flow (which
# uses the LLM's typically-sub-midpoint per-project proposal) instead of overstating them. Clamped
# to [0, 1]. (Discovery/UX always use the midpoint, matching the twins.)
WBS_AI_REDUCTION_ANCHOR=0.3
# Drafts the project-specific prose of an exported Statement of Work:
ANTHROPIC_MODEL_SOW=claude-sonnet-4-6
# The delivering firm's name printed on exported Statements of Work. No firm is hardcoded in
# the repo: set it here to inject your brand at deploy time (overrides the SOW template's
# branding.company). Leave blank to use the template default ("Your Company").
SOW_COMPANY_NAME=
# LLM-as-judge model for the evals harness (backend/evals/):
ANTHROPIC_MODEL_EVAL=claude-sonnet-4-6
# Self-hosted docs-mcp-server the tooling classifier consults (as an MCP client over
# streamable HTTP) for tools it doesn't recognize. This is the HOST value for a
# `make be` backend; the docker-compose backend hardcodes the in-network hostname
# (http://docs-mcp-server:6280/mcp) and ignores this, like NEO4J_URI.
# Blank it to disable lookups (unknown tools then map to 'none'). Auth token optional.
DOCS_MCP_URL=http://localhost:6280/mcp
DOCS_MCP_AUTH_TOKEN=
# Hard ceiling (seconds) on the docs-mcp SEARCH-only lookup so a slow/unreachable MCP
# server never hangs Stage 3 submit; on timeout the unrecognized tools map to 'none'.
DOCS_MCP_RESEARCH_TIMEOUT_S=25
# When true, an unrecognized tool that isn't in the docs-mcp index yet is SCRAPED
# (its latest docs indexed) before the estimate continues, then searched. Scraping is
# slow, so it uses the larger timeout below. Requires OPENAI_API_KEY on the
# docs-mcp-server service (below). Set false to only search the existing index.
DOCS_MCP_AUTO_SCRAPE=true
DOCS_MCP_SCRAPE_TIMEOUT_S=240
# SSRF / prompt-injection hardening for the in-process docs-mcp research loop. The backend
# blocks the LLM from fetching internal/private/metadata addresses regardless of these. Optionally
# restrict fetch/scrape to specific doc domains (comma-separated, suffix match); empty = no domain
# restriction (private-range block still applies). And cap tool calls per research run.
DOCS_MCP_URL_ALLOWLIST=
DOCS_MCP_MAX_TOOL_CALLS=25
# OpenAI key — authenticates: (1) the eval harness LLM-as-judge (make evals), (2) the docs-mcp-server
# embeddings provider (REQUIRED for scraping/indexing AND search to return anything; leave blank to
# disable doc indexing → unknown tools fall back to the model's own knowledge / 'none'), and (3) the
# WBS planner/completeness ONLY IF you set WBS_MODEL to a gpt-* id (the default is Anthropic Opus).
OPENAI_API_KEY=
DOCS_MCP_EMBEDDING_MODEL=text-embedding-3-small
# Override per twin if you want different tiers post-MVP:
#   ANTHROPIC_MODEL_DISCOVERY=claude-haiku-4-5-20251001
#   ANTHROPIC_MODEL_DEVELOPMENT=claude-opus-4-5-20250929

# ---- Neo4j (required for checkpointer) ----
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-please
NEO4J_DATABASE=neo4j

# ---- Qdrant (vector-similarity calibration store) ----
# Completed estimates are embedded and indexed here for reference-class lookups (additive to
# Neo4j/Postgres; degrades silently when absent). Indexing needs OPENAI_API_KEY for embeddings.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
# OpenAI embedding model used to vectorize estimates into Qdrant (pinned to 1536 dims):
EMBEDDING_MODEL=text-embedding-3-small

# ---- Postgres (historical estimates + twin calibration) ----
# Discrete vars (used by compose to build POSTGRES_DSN automatically):
POSTGRES_USER=estimator
POSTGRES_PASSWORD=changeme-please
POSTGRES_DB=estimator
# Full async DSN; overrides the discrete vars if both are set.
# Example for local-host backend (outside docker-compose):
#   postgresql+asyncpg://estimator:changeme-please@localhost:5432/estimator
POSTGRES_DSN=
# Run Alembic upgrade head on backend startup. Safe to leave true in dev.
POSTGRES_MIGRATE_ON_START=true

# ---- Backend ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
